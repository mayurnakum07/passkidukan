{
  "name": "e-comm-expo",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "node scripts/createNetworkSecurityConfig.js && expo prebuild --clean",
    "prebuild:android": "node scripts/createNetworkSecurityConfig.js && expo prebuild --platform android --clean",
    "build:apk": "node -e \"require('child_process').execSync('build-apk.bat', {stdio: 'inherit'})\"",
    "build:android": "node scripts/createNetworkSecurityConfig.js && expo prebuild --platform android --clean && cd android && gradlew.bat assembleRelease && cd ..",
    "build:dev-client": "node scripts/createNetworkSecurityConfig.js && expo prebuild --clean && npx expo run:android",
    "setup:network-config": "node scripts/createNetworkSecurityConfig.js"
  },
  "dependencies": {
