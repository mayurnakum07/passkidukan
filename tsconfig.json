{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "target": "ESNext",
    "lib": [
      "DOM",
      "ESNext"
    ]
  },
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "android",
    "ios"
  ],
  "extends": "expo/tsconfig.base"
}
